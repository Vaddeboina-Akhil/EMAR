# PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env.production and fill in actual values

NODE_ENV=production
PORT=3000

# DATABASE
# Get from MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/databasename
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/emar

# JWT SECRET - Generate a strong random string (min 32 characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random-min-32-chars

# ENCRYPTION KEY - Must be exactly 32 bytes (64 hex characters)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-encryption-key-here-must-be-32-bytes

# CORS - Your frontend domain
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# BLOCKCHAIN (Optional - for record integrity)
BLOCKCHAIN_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
PRIVATE_KEY=your-ethereum-private-key-here
CONTRACT_ADDRESS=your-deployed-smart-contract-address

# AI APIs (Optional)
AI_API_KEY=your-openai-or-gemini-api-key-here

# FRONTEND API URL (for frontend .env)
# This should point to your deployed backend
VITE_API_URL=https://your-backend-domain.vercel.app/api
